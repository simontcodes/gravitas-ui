{
  "assets": [
    {
      "glob": "LICENSE",
      "input": ".",
      "output": "."
    },
    {
      "glob": "SECURITY.md",
      "input": ".",
      "output": "."
    },
    {
      "glob": "CHANGELOG.md",
      "input": ".",
      "output": "."
    },
    {
      "glob": "**/*",
      "input": "src/ai",
      "output": "ai"
    },
    {
      "glob": "**/*",
      "input": "src/styles",
      "output": "styles"
    }
  ],
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/gravitas-ui",
  "lib": {
    "entryFile": "src/public-api.ts"
  }
}
